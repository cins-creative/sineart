# Copy to `.env.local` and điền giá trị thật (không commit `.env.local`).

# --- Admin /admin (JWT cookie + link trong email quên mật khẩu) ---
# Chuỗi ngẫu nhiên ≥ 32 ký tự. Tạo nhanh: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
ADMIN_SESSION_SECRET=

# Resend (gửi email admin + biên nhận học phí)
RESEND_API_KEY=
RESEND_FROM=Sine Art <noreply@your-verified-domain.com>

# Site URL trong link email (production)
NEXT_PUBLIC_SITE_URL=https://sineart.vn

# --- Trang đóng học phí / VietQR (sineart.vn/donghocphi) ---
# Bật QR thử 2.000–2.300 ₫ (mã SA… vẫn đủ để SePay khớp theo nội dung CK). Bắt buộc nếu chạy `next start` hoặc Vercel production mà muốn thử CK nhỏ.
# Tắt: 0 hoặc false. Mặc định `next dev` = bật (trừ khi đặt 0).
# NEXT_PUBLIC_DHP_TEST_MICRO_QR=1
