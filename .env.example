# Copy to `.env.local` and điền giá trị thật (không commit `.env.local`).

# --- Admin /admin (JWT cookie + link trong email quên mật khẩu) ---
# Chuỗi ngẫu nhiên ≥ 32 ký tự. Tạo nhanh: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
ADMIN_SESSION_SECRET=

# Resend (gửi email admin + biên nhận học phí)
RESEND_API_KEY=
RESEND_FROM=Sine Art <noreply@your-verified-domain.com>

# Site URL trong link email (production)
NEXT_PUBLIC_SITE_URL=https://sineart.vn

# --- Google Analytics 4 (traffic web admin + đo site public) ---
# Measurement ID — gắn tag lên site (public)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
# Property ID số (Admin GA4 → Property settings)
GA4_PROPERTY_ID=
# Service account — quyền Viewer trên GA4 property (admin API đọc biểu đồ)
GA4_CLIENT_EMAIL=
GA4_PRIVATE_KEY=

# --- Google Search Console (tab Google Search admin) ---
# Domain property: sc-domain:sineart.vn — URL prefix: https://www.sineart.vn/
GSC_SITE_URL=
# OAuth Web client (Owner GSC — khuyến nghị; service account GSC UI thường không add được)
GSC_OAUTH_CLIENT_ID=
GSC_OAUTH_CLIENT_SECRET=
GSC_OAUTH_REFRESH_TOKEN=

# --- Meta Graph API (Fanpage + Ads insights — tab Meta FB admin) ---
# System User token từ Business Manager (không hết hạn 60 ngày nếu tạo đúng)
META_ACCESS_TOKEN=
META_PAGE_ID=
# Tuỳ chọn — để có chi phí Ads, tin nhắn, click
META_AD_ACCOUNT_ID=

# --- Worker upload ảnh Cloudflare (/admin/api/upload-cf-image → Worker POST /upload-cf-images) ---
# Secret trùng Wrangler secret API_SECRET của Worker sine-art-api (KHÔNG phải Worker Messenger Agent).
SINE_ART_WORKER_SECRET=
# Origin Worker (một worker gộp): upload-cf-images + Messenger /agent/* — mặc định sine-art-api workers.dev.
# SINE_ART_WORKER_URL=https://sine-art-api.xxx.workers.dev

# Client admin «Agent tư vấn» — GET conversations / POST toggle (cùng origin upload nếu đã gộp Worker).
# NEXT_PUBLIC_AGENT_WORKER_URL=https://sine-art-api.xxx.workers.dev

# --- LiveKit phòng học trực tuyến (/phong-hoc/[slug]) ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- CINS Supabase (ngành học / hướng nghiệp — server fetch) ---
CINS_NEXT_PUBLIC_SUPABASE_URL=
CINS_NEXT_PUBLIC_SUPABASE_ANON_KEY=
CINS_SUPABASE_SERVICE_ROLE_KEY=
# Site CINS public (bài viết ngành): https://cins.vercel.app/nganh-hoc/[slug]
CINS_PUBLIC_SITE_URL=
# NEXT_PUBLIC_CINS_PUBLIC_SITE_URL=
# Alias cũ (vẫn hỗ trợ):
# NEXT_PUBLIC_CINS_SUPABASE_URL=
# NEXT_PUBLIC_CINS_SUPABASE_ANON_KEY=

ANTHROPIC_API_KEY=
